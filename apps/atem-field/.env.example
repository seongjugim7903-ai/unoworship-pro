# UnoLive deployment safety defaults
# Copy only the keys you need into .env.local. Do not commit real secrets.

# Server
PORT=3000
UNOLIVE_BIND_HOST=0.0.0.0

# Strict host/origin allowlist.
# 1 = only localhost plus UNOLIVE_ALLOWED_LAN_HOSTS can reach the server.
# Development without this set allows private LAN fallback for easier local testing.
UNOLIVE_STRICT_HOSTS=1

# 1 or unset = automatically allow this Mac's current private LAN IPv4 addresses.
# Set to 0 only when you want a fully manual allowlist.
UNOLIVE_AUTO_ALLOW_LOCAL_LAN=1

# Server PC LAN IP and allowed browser hosts.
# Example for the current church LAN:
# UNOLIVE_SERVER_LAN_IP=192.168.0.8
# UNOLIVE_ALLOWED_LAN_HOSTS=localhost,127.0.0.1,192.168.0.8
UNOLIVE_SERVER_LAN_IP=
UNOLIVE_ALLOWED_LAN_HOSTS=localhost,127.0.0.1

# Write API Origin/Referer allowlist.
# Usually keep this identical to UNOLIVE_ALLOWED_LAN_HOSTS.
UNOLIVE_ALLOWED_WRITE_ORIGINS=localhost,127.0.0.1

# Health endpoint stays authenticated unless explicitly opened for local checks.
UNOLIVE_HEALTH_PUBLIC=0

# Supabase (cloud auth / church data). Optional for field-only offline use.
# When unset, the app boots in guest mode with cloud features disabled.
# anon key is a public client key; never put SUPABASE_SERVICE_ROLE_KEY here.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
