{
  "name": "unolive",
  "version": "0.1.1",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "tsx server.ts",
    "dev:watch": "tsx watch --clear-screen=false server.ts",
    "build": "next build",
    "build:server": "node scripts/build-server-bundle.mjs",
    "start": "cross-env NODE_ENV=production tsx server.ts",
    "lint": "eslint",
    "generate:ppt": "node generator/ppt-slides/generate-ppt-slides.mjs",
    "install:hymn-local": "node scripts/install-local-hymn-lyrics.mjs",
    "install:bible-local": "node scripts/install-local-bible.mjs",
    "install:bible-local:krv": "node scripts/install-local-bible.mjs --from-existing-krv",
    "electron": "electron .",
    "electron:dev": "cross-env NODE_ENV=development electron .",
    "electron:build": "npm run build && npm run build:server && electron-builder",
    "electron:pack": "npm run build && npm run build:server && electron-builder --dir"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@imgly/background-removal": "^1.7.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.103.0",
    "atem-connection": "^3.9.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "pdfjs-dist": "^5.6.205",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "shadcn": "^4.0.0",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3",
    "wait-on": "^9.0.5"
  },
  "build": {
    "appId": "kr.unoworship.pro",
    "productName": "UnoWorship Pro",
    "copyright": "© 2026 UnoMedia",
    "asar": true,
    "directories": {
      "buildResources": "build",
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "package.json",
      "!**/*.map"
    ],
    "extraResources": [
      { "from": ".next/standalone", "to": "app-server" },
      { "from": ".next/standalone/node_modules", "to": "app-server/node_modules" },
      { "from": ".next/static", "to": "app-server/.next/static" },
      { "from": "public", "to": "app-server/public" }
    ],
    "mac": {
      "target": {
        "target": "dmg",
        "arch": [
          "arm64",
          "x64"
        ]
      },
      "category": "public.app-category.video",
      "icon": "build/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "extendInfo": {
        "LSUIElement": false,
        "NSCameraUsageDescription": "UnoLive 는 라이브 방송을 위해 카메라에 접근합니다.",
        "NSMicrophoneUsageDescription": "UnoLive 는 라이브 방송을 위해 마이크에 접근합니다."
      }
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.png"
    },
    "linux": {
      "target": "AppImage",
      "category": "AudioVideo",
      "icon": "build/icon.png"
    },
    "dmg": {
      "title": "UnoWorship Pro ${version}",
      "backgroundColor": "#0a0a0a",
      "window": {
        "width": 540,
        "height": 380
      },
      "contents": [
        {
          "x": 140,
          "y": 190,
          "type": "file"
        },
        {
          "x": 400,
          "y": 190,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  }
}
